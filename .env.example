# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=

# Database — leave blank to use local SQLite; set to your Neon URL in production
# Example: postgresql://user:pass@ep-xxx.neon.tech/dbname
DATABASE_URL=

# OpenRouter (text AI — scripts, emails, captions)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# fal.ai (video + images)
FAL_API_KEY=

# ElevenLabs (voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
