# Copy to .env and fill in. Never commit the real .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=

# Database — leave blank to use local SQLite; set to your Neon URL in production
# Example: postgresql://user:pass@ep-xxx.neon.tech/dbname
DATABASE_URL=

# OpenRouter (text AI — scripts, emails, captions)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# fal.ai (video + images)
FAL_API_KEY=

# ElevenLabs (voiceover)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Resend (email delivery)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Upload-Post (publish video to YouTube/TikTok/Instagram via one API)
# UPLOAD_POST_USER = the profile name you create in the Upload-Post dashboard
UPLOAD_POST_API_KEY=
UPLOAD_POST_USER=

# Cloudflare R2 (media storage). Leave blank to use local files in dev.
# Create a bucket, an S3 API token, and enable public access in the R2 dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL: a custom domain (https://media.yoursite.com) or the pub-xxx.r2.dev URL
R2_PUBLIC_URL=
