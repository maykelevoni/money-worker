# Public entrypoint for the Money Worker app.
# SITE_HOST is injected into the caddy container's environment (see
# docker-compose.yml); Caddy expands {$SITE_HOST} at runtime. It fetches +
# renews a Let's Encrypt cert automatically (TOS auto-accepted; an email is
# optional and only used for expiry notices) and proxies to the Django app.
#
# Forwards X-Forwarded-Proto=https, which Django trusts via
# SECURE_PROXY_SSL_HEADER (config/settings.py) so it knows the request is secure.
#
# Serves the apex + www. Generated public sites on other subdomains would need a
# wildcard cert via the Cloudflare DNS challenge — not configured here.
{$SITE_HOST}, www.{$SITE_HOST} {
	reverse_proxy web:8000
}
